# SerpApi key for fetching Google Flights
SERPAPI_KEY=your_serpapi_key_here

# Vercel KV Redis credentials (automatically filled in Vercel, copy from Vercel KV page for local testing)
KV_URL=rediss://default:placeholder@placeholder.upstash.io:6379
KV_REST_API_URL=https://placeholder.upstash.io
KV_REST_API_TOKEN=placeholder_token
KV_REST_API_READ_ONLY_TOKEN=placeholder_readonly_token
